	note = {Num Pages: 33
Web of Science ID: WOS:001273911300001},
	keywords = {Authenticity, CAPTIONS, credibility, digital manipulation disclosure, DISCLAIMER, INVOLVEMENT, MODEL, PERSUASION KNOWLEDGE, PRODUCT, product involvement, RECOGNITION, RESPONSES, social media influencers, SPONSORED CONTENT, WOMENS BODY-IMAGE},
