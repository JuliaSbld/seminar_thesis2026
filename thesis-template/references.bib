	note = {Num Pages: 22
Web of Science ID: WOS:001320723300001},
	keywords = {ad credibility, AI-generated content, ANTHROPOMORPHISM, BRAND CREDIBILITY, CONSUMER, disclosure language, LANGUAGE, MEDIA, MIND, perceived AI human-likeness, PERCEPTIONS, PERSUASION KNOWLEDGE, prosocial advertising, TRUST, WILLINGNESS},
	pages = {171--192},
	file = {Full Text PDF:/Users/juliaseibold/Zotero/storage/SN7MFAIG/Baek et al. - 2026 - Effect of disclosing AI-generated content on prosocial advertising evaluation.pdf:application/pdf},
