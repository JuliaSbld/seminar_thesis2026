Web of Science ID: WOS:000592621500001},
	keywords = {arousal, CANCER-PATIENTS, GUIDED IMAGERY, HOSPITALIZED-PATIENTS, multilevel meta-analysis, music intervention, Music therapy, ORGAN TRANSPLANT UNIT, PALLIATIVE CARE, PREFERRED LIVE MUSIC, PSYCHIATRIC-PATIENTS, PUBLICATION BIAS, RANDOMIZED CONTROLLED-TRIAL, state anxiety, STEM-CELLS, stress},
