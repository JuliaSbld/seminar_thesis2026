	pages = {682--696},
	file = {Full Text:/Users/juliaseibold/Zotero/storage/A5LAILFW/Orben and Przybylski - 2019 - Screens, Teens, and Psychological Well-Being Evidence From Three Time-Use-Diary Studies.pdf:application/pdf},
