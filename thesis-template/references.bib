	keywords = {5-FACTOR MODEL, ADDICTIONS, COLLEGE-STUDENTS, Compulsive usage, DARK SIDE, IMPACT, INTERNET, MOTIVATIONS, Personality traits, PHONE USE, PREDICTORS, SMARTPHONE, Social apps, Technostress, Universal access and usability},
