	keywords = {addiction, ADOLESCENTS, attention, COMPUTER, DEFICIT, DOPAMINE, eye-tracking, EYE-TRACKING, HYPERACTIVITY, INTERNET ADDICTION, MENTAL-HEALTH, MOBILE PHONE, Short-form videos, Stroop task, STROOP TASK, user characteristics},
	pages = {2893--2910},
